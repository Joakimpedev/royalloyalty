{% comment %}
  Royal Loyalty - customer-account block. Renders inside the storefront
  customer account page. Self-isolating CSS so it looks the same on every
  theme. Reads branding from shop metafields so colors and copy match the
  admin Branding live preview.
{% endcomment %}

<link rel="stylesheet" href="{{ 'loyalty.css' | asset_url }}">

{%- assign mf_primary = shop.metafields.royal_loyalty.primary_color -%}
{%- assign mf_secondary = shop.metafields.royal_loyalty.secondary_color -%}
{%- if mf_primary != blank -%}
  {%- assign primary = mf_primary -%}
{%- else -%}
  {%- assign primary = block.settings.accent | default: '#2C2A29' -%}
{%- endif -%}
{%- if mf_secondary != blank -%}
  {%- assign secondary = mf_secondary -%}
{%- else -%}
  {%- assign secondary = '#FFFFFF' -%}
{%- endif -%}

<section
  id="royal-account-root"
  class="royal-account"
  style="--royal-primary: {{ primary }}; --royal-secondary: {{ secondary }};"
  data-royal-config='{
    "proxy": {{ block.settings.proxy_base | default: "/apps/royal" | json }},
    "loggedIn": {% if customer %}true{% else %}false{% endif %}
  }'
>
  <h2 class="royal-account__heading" data-loc-key="account.heading">{{ block.settings.heading | default: 'Your loyalty' | escape }}</h2>

  {%- if customer -%}
    <div class="royal-account__balance-card">
      <div class="royal-account__balance-label" data-loc-key="account.balanceLabel">Points balance</div>
      <div class="royal-account__balance-row">
        <span id="royal-acc-balance" class="royal-account__balance-num">&hellip;</span>
        <span class="royal-account__balance-suffix" data-loc-key="account.pointsSuffix">points</span>
      </div>
      <div id="royal-acc-tier" class="royal-account__tier" hidden></div>
    </div>

    <h3 class="royal-account__section-h" data-loc-key="account.recentActivityHeading">Recent activity</h3>
    <div id="royal-acc-activity" class="royal-account__activity">
      <p class="royal-account__muted" data-loc-key="page.loading">Loading&hellip;</p>
    </div>

    <h3 class="royal-account__section-h" data-loc-key="account.rewardsHeading">Rewards</h3>
    <div id="royal-acc-rewards" class="royal-account__rewards">
      <p class="royal-account__muted" data-loc-key="page.loading">Loading&hellip;</p>
    </div>

    <h3 class="royal-account__section-h" data-loc-key="account.referHeading">Refer a friend</h3>
    <div class="royal-account__referral-card">
      <code id="royal-acc-ref" class="royal-account__referral-link">&hellip;</code>
      <button type="button" id="royal-acc-copy" class="royal-account__btn royal-account__btn--ghost" data-loc-key="account.referCopyButton">Copy link</button>
    </div>
  {%- else -%}
    <div class="royal-account__signin">
      <p data-loc-key="account.signInRequired">Please sign in to view your loyalty status.</p>
    </div>
  {%- endif -%}

  <p id="royal-acc-status" class="royal-status" aria-live="polite"></p>
</section>

<script src="{{ 'loyalty.js' | asset_url }}" defer></script>
<script>
  (function () {
    function init() {
      var root = document.getElementById('royal-account-root');
      if (!root || !window.RoyalLoyalty) return setTimeout(init, 50);
      var R = window.RoyalLoyalty, cfg = R.readConfig(root);
      if (!cfg.loggedIn) return;
      var status = document.getElementById('royal-acc-status');

      R.loadBalance(cfg, function (d) {
        R.applyBranding(root, d.branding);

        // Apply locale-resolved strings to every data-loc-key element.
        var locNodes = root.querySelectorAll('[data-loc-key]');
        for (var i = 0; i < locNodes.length; i++) {
          var k = locNodes[i].getAttribute('data-loc-key');
          var v = R.t(k, '');
          if (v) locNodes[i].textContent = v;
        }

        var b = document.getElementById('royal-acc-balance');
        if (b) b.textContent = (d.balance || 0).toLocaleString();

        var tierEl = document.getElementById('royal-acc-tier');
        if (tierEl && d.currentTier) {
          tierEl.hidden = false;
          var rawTierName = d.currentTier.name || '';
          // Resolve a localized tier name when the slug is one of the known
          // canonical ones (bronze/silver/gold/platinum). Custom merchant
          // names fall back to the raw display name.
          var tierSlug = rawTierName.toLowerCase();
          var tierKey = (tierSlug === 'bronze' || tierSlug === 'silver' || tierSlug === 'gold' || tierSlug === 'platinum')
            ? 'tier.' + tierSlug
            : null;
          var locTierName = tierKey ? R.t(tierKey, rawTierName) : rawTierName;
          tierEl.textContent = R.tSubstitute(
            R.t('tier.memberSuffix', '{tierName} member'),
            { tierName: locTierName },
          );
        }

        var act = document.getElementById('royal-acc-activity');
        if (act) {
          // Every customer-facing label here goes through R.t() so the
          // active locale's translation wins. The structured kind+meta
          // server-side fields tell us WHICH key to pick.
          function redeemPhrase(meta) {
            var type = (meta && meta.rewardType) || '';
            var pts = meta && meta.pointsCost != null ? meta.pointsCost : 0;
            var keyMap = {
              store_credit:  'activity.redeemStoreCredit',
              amount_off:    'activity.redeemAmountOff',
              percent_off:   'activity.redeemPercentOff',
              free_shipping: 'activity.redeemFreeShipping',
              free_product:  'activity.redeemFreeProduct',
            };
            var k = keyMap[type] || 'activity.redeemGeneric';
            return R.tSubstitute(R.t(k, 'Redeemed {points} points'), { points: pts });
          }
          function earnPhrase(meta) {
            var a = (meta && meta.earnAction) || 'reward';
            var keyMap = {
              purchase:    'activity.earnPurchase',
              signup:      'activity.earnSignup',
              birthday:    'activity.earnBirthday',
              review:      'activity.earnReview',
              social:      'activity.earnSocial',
              newsletter:  'activity.earnNewsletter',
              anniversary: 'activity.earnAnniversary',
            };
            var k = keyMap[a] || 'activity.earnGeneric';
            return R.t(k, 'Earned points');
          }
          function activityLabel(a) {
            var k = a.kind;
            var m = a.meta || {};
            if (k === 'referral_referrer') {
              return m.refereeEmail
                ? R.tSubstitute(R.t('activity.referredEmail', 'Referred {email}'), { email: m.refereeEmail })
                : R.t('activity.referredFriend', 'Referred a friend');
            }
            if (k === 'referral_referee') {
              return m.referrerEmail
                ? R.tSubstitute(R.t('activity.welcomeBonusFrom', 'Welcome bonus from {email}'), { email: m.referrerEmail })
                : R.t('activity.welcomeBonus', 'Welcome referral bonus');
            }
            if (k === 'redeem') return redeemPhrase(m);
            if (k === 'earn') return earnPhrase(m);
            if (k === 'migration') return R.t('activity.balanceImported', 'Balance imported');
            if (k === 'reversal') return R.t('activity.redemptionReversed', 'Redemption reversed');
            return a.reason;
          }
          var ptsSuffix = R.t('common.ptsSuffix', ' pts');
          act.innerHTML = (d.activity && d.activity.length)
            ? d.activity.map(function (a) {
                var dateStr = (function () {
                  try { return new Date(a.date).toLocaleDateString(); }
                  catch (e) { return a.date; }
                })();
                var label = activityLabel(a);
                return '<div class="royal-account__activity-row">' +
                  '<div class="royal-account__activity-reason">' + label + '</div>' +
                  '<div class="royal-account__activity-meta">' +
                    '<span class="royal-account__activity-points">' + (a.points > 0 ? '+' : '') + a.points + ptsSuffix + '</span>' +
                    '<span class="royal-account__activity-date">' + dateStr + '</span>' +
                  '</div>' +
                  '</div>';
              }).join('')
            : '<p class="royal-account__muted">' + R.t('account.emptyActivity', 'No activity yet. Place an order to start earning.') + '</p>';
        }
        var rw = document.getElementById('royal-acc-rewards');
        if (rw) {
          var ptsSuffixR = R.t('common.ptsSuffix', ' pts');
          rw.innerHTML = (d.rewards && d.rewards.length)
            ? d.rewards.map(function (x) {
                return '<div class="royal-account__reward-row">' +
                  '<span class="royal-account__reward-label">' + R.rewardLabel(x, d.currencyCode) + '</span>' +
                  '<span class="royal-account__reward-cost">' + x.pointsCost + ptsSuffixR + '</span>' +
                  '</div>';
              }).join('')
            : '<p class="royal-account__muted">' + R.t('empty.rewards', 'No rewards available yet. Check back soon.') + '</p>';
        }
        var ref = document.getElementById('royal-acc-ref');
        if (ref && d.referralLink) {
          ref.textContent = d.referralLink;
          var c = document.getElementById('royal-acc-copy');
          if (c) c.addEventListener('click', function () {
            try {
              navigator.clipboard.writeText(d.referralLink);
              R.setStatus(status, 'success', R.t('common.linkCopied', 'Link copied.'));
            } catch (e) {
              R.setStatus(status, 'error', R.t('common.linkCopyFailedAuto', 'Could not copy automatically.'));
            }
          });
        }
      }, function () {
        R.setStatus(status, 'error',
          R.t('account.couldNotLoad', "We couldn't load your loyalty status right now. Please try again later."));
      });
    }
    init();
  })();
</script>

{% schema %}
{
  "name": "Loyalty account",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your loyalty" },
    { "type": "color", "id": "accent", "label": "Fallback accent", "default": "#2C2A29" },
    { "type": "text", "id": "proxy_base", "label": "App proxy base path", "default": "/apps/royal" }
  ]
}
{% endschema %}
