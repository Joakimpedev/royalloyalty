{% comment %}
  Royal Loyalty — product-page points indicator. App block placed in a product
  template. Shows how many points this product earns. Pure Liquid math from the
  product price + the block's points-per-currency setting (no network call =
  zero Lighthouse cost); falls back silently if price is unavailable.
{% endcomment %}

<link rel="stylesheet" href="{{ 'loyalty.css' | asset_url }}">

{%- assign ppu = block.settings.points_per_unit | default: 1 -%}
{%- assign price_units = product.price | divided_by: 100 -%}
{%- assign pts = price_units | times: ppu | floor -%}

{%- if pts > 0 -%}
  <p class="royal-card" style="display:flex;align-items:center;gap:8px;">
    <span aria-hidden="true" style="color: {{ block.settings.accent | default: '#5C3D2E' }};">&#9819;</span>
    <span>
      {{ block.settings.label_prefix | default: 'Earn' | escape }}
      <span class="royal-points">{{ pts }}</span>
      {{ block.settings.label_suffix | default: 'points with this purchase' | escape }}
    </span>
  </p>
{%- endif -%}

{% schema %}
{
  "name": "Product points",
  "target": "section",
  "settings": [
    { "type": "number", "id": "points_per_unit", "label": "Points per currency unit", "default": 1 },
    { "type": "text", "id": "label_prefix", "label": "Prefix", "default": "Earn" },
    { "type": "text", "id": "label_suffix", "label": "Suffix", "default": "points with this purchase" },
    { "type": "color", "id": "accent", "label": "Accent", "default": "#5C3D2E" }
  ],
  "presets": [{ "name": "Product points" }]
}
{% endschema %}
