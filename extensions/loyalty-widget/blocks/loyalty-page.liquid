{% comment %}
  Royal Loyalty - full loyalty page block (add to a page template / section).
  Self-isolating CSS root (.royal-page) so the block looks the same on every
  theme. Reads branding from shop metafields the admin Branding page writes,
  so colors and copy match the live preview without a JS roundtrip.
{% endcomment %}

<link rel="stylesheet" href="{{ 'loyalty.css' | asset_url }}">

{%- comment -%}
  Branding metafields take precedence over the theme-editor block setting,
  same priority order as launcher.liquid. Lets a merchant edit the Branding
  page once and have it reflected in every block without re-editing the
  theme.
{%- endcomment -%}
{%- assign mf_primary = shop.metafields.royal_loyalty.primary_color -%}
{%- assign mf_secondary = shop.metafields.royal_loyalty.secondary_color -%}
{%- assign mf_hero_title = shop.metafields.royal_loyalty.hero_title -%}
{%- assign mf_hero_subtitle = shop.metafields.royal_loyalty.hero_subtitle -%}
{%- assign mf_points_name = shop.metafields.royal_loyalty.points_name -%}

{%- if mf_primary != blank -%}
  {%- assign primary = mf_primary -%}
{%- else -%}
  {%- assign primary = block.settings.theme_color | default: '#2C2A29' -%}
{%- endif -%}
{%- if mf_secondary != blank -%}
  {%- assign secondary = mf_secondary -%}
{%- else -%}
  {%- assign secondary = '#FFFFFF' -%}
{%- endif -%}
{%- if mf_hero_title != blank -%}
  {%- assign hero_title = mf_hero_title -%}
{%- else -%}
  {%- assign hero_title = block.settings.hero_title | default: 'Earn points. Get rewards.' -%}
{%- endif -%}
{%- if mf_hero_subtitle != blank -%}
  {%- assign hero_subtitle = mf_hero_subtitle -%}
{%- else -%}
  {%- assign hero_subtitle = block.settings.hero_subtitle | default: 'Join the program and earn on every order.' -%}
{%- endif -%}

<section
  id="royal-page-root"
  class="royal-page"
  style="--royal-primary: {{ primary }}; --royal-secondary: {{ secondary }};"
  data-royal-config='{
    "proxy": {{ block.settings.proxy_base | default: "/apps/royal" | json }},
    "loggedIn": {% if customer %}true{% else %}false{% endif %}
  }'
>
  <header class="royal-page__hero">
    {%- if block.settings.logo_url != blank -%}
      <img class="royal-page__logo" src="{{ block.settings.logo_url }}" alt="">
    {%- endif -%}
    <h1 class="royal-page__title" data-loc-key="page.heroTitle">{{ hero_title | escape }}</h1>
    <p class="royal-page__sub" data-loc-key="page.heroSubtitle">{{ hero_subtitle | escape }}</p>
  </header>

  {%- if customer -%}
    <div class="royal-page__balance-card">
      <div class="royal-page__balance-grid">
        <div class="royal-page__balance-col">
          <div class="royal-page__balance-label" data-loc-key="page.balanceLabel">Points balance</div>
          <div class="royal-page__balance-value">
            <span id="royal-page-balance" class="royal-page__balance-num">&hellip;</span>
            <span class="royal-page__balance-suffix">{{ mf_points_name | default: 'points' }}</span>
          </div>
          <div id="royal-page-tier-line" class="royal-page__tier-line" hidden></div>
        </div>
        <div class="royal-page__balance-col royal-page__balance-col--credit">
          <div class="royal-page__balance-label" data-loc-key="page.storeCreditLabel">Store credit</div>
          <div class="royal-page__balance-value">
            <span id="royal-page-storecredit" class="royal-page__balance-num">&hellip;</span>
          </div>
          <div class="royal-page__balance-caption" data-loc-key="page.storeCreditCaption">Applied at checkout, no code needed</div>
        </div>
      </div>
    </div>
  {%- else -%}
    <div class="royal-page__signin">
      <p class="royal-page__signin-text" data-loc-key="page.signinPrompt">Sign in to see your points and unlock rewards.</p>
      <a class="royal-page__btn" href="/account/login" data-loc-key="page.signInCta">Sign in</a>
    </div>
  {%- endif -%}

  <div id="royal-page-cashback-wrap" hidden>
    <div class="royal-page__cashback" id="royal-page-cashback"></div>
  </div>

  <div id="royal-page-tier-grid-wrap" class="royal-page__tier-section" hidden>
    <h2 class="royal-page__section-h" data-loc-key="page.tiersHeading">VIP program</h2>
    <div id="royal-page-tier-grid" class="royal-tier-grid"></div>
  </div>

  {%- if block.settings.show_earn -%}
    <h2 class="royal-page__section-h" data-loc-key="page.waysToEarnHeading">Ways to earn</h2>
    <div id="royal-page-earn" class="royal-page__grid"><p class="royal-page__muted" data-loc-key="page.loading">Loading&hellip;</p></div>
  {%- endif -%}

  {%- if block.settings.show_rewards -%}
    <h2 class="royal-page__section-h" data-loc-key="page.rewardsHeading">Rewards</h2>
    <div id="royal-page-rewards" class="royal-page__reward-list"><p class="royal-page__muted" data-loc-key="page.loading">Loading&hellip;</p></div>
  {%- endif -%}

  <div id="royal-page-social-wrap" hidden>
    <h2 class="royal-page__section-h" data-loc-key="page.followUsHeading">Follow us</h2>
    <div id="royal-page-social" class="royal-page__grid"></div>
  </div>

  {%- if block.settings.show_referral and customer -%}
    <h2 class="royal-page__section-h" data-loc-key="page.referHeading">Refer a friend</h2>
    <p class="royal-page__referral-desc" data-loc-key="page.referDescription">Share your link. You both get rewarded.</p>
    <div class="royal-page__referral-card">
      <code id="royal-ref-link" class="royal-page__referral-link" data-loc-key="page.referLoadingLink">Loading your link&hellip;</code>
      <button type="button" id="royal-ref-copy" class="royal-page__btn royal-page__btn--ghost" data-loc-key="page.referCopyButton">Copy link</button>
    </div>
  {%- endif -%}

  <p id="royal-page-status" class="royal-status" aria-live="polite"></p>
</section>

<script src="{{ 'loyalty.js' | asset_url }}" defer></script>
<script>
  (function () {
    function init() {
      var root = document.getElementById('royal-page-root');
      if (!root || !window.RoyalLoyalty) return setTimeout(init, 50);
      var R = window.RoyalLoyalty, cfg = R.readConfig(root);
      var status = document.getElementById('royal-page-status');

      R.loadBalance(cfg, function (d) {
        R.applyBranding(root, d.branding);

        // Apply locale-resolved strings to every Liquid element marked
        // with data-loc-key. Branding-level overrides for heroTitle /
        // heroSubtitle still take precedence.
        var locNodes = root.querySelectorAll('[data-loc-key]');
        for (var i = 0; i < locNodes.length; i++) {
          var k = locNodes[i].getAttribute('data-loc-key');
          var v = R.t(k, '');
          if (v) locNodes[i].textContent = v;
        }

        if (d.branding) {
          var heroH1 = root.querySelector('.royal-page__title');
          if (heroH1 && d.branding.heroTitle) heroH1.textContent = d.branding.heroTitle;
          var heroP = root.querySelector('.royal-page__sub');
          if (heroP && d.branding.heroSubtitle) heroP.textContent = d.branding.heroSubtitle;
        }

        renderBalances(d);
        renderRewards(d);

        function renderBalances(d) {
          if (!d.enrolled) return;
          var b = document.getElementById('royal-page-balance');
          if (b) b.textContent = (d.balance || 0).toLocaleString();

          var sc = document.getElementById('royal-page-storecredit');
          if (sc) {
            var amount = d.storeCreditBalance || 0;
            var curr = d.storeCreditCurrency || d.currencyCode || 'USD';
            sc.textContent = R.formatMoney
              ? R.formatMoney(amount, curr)
              : (curr + ' ' + Number(amount).toFixed(2));
          }

          var tierLine = document.getElementById('royal-page-tier-line');
          if (tierLine && d.currentTier) {
            tierLine.hidden = false;
            tierLine.textContent = d.currentTier.name + ' member';
          }
        }

        // Cashback callout only when the merchant has it enabled.
        var cbWrap = document.getElementById('royal-page-cashback-wrap');
        var cbCard = document.getElementById('royal-page-cashback');
        if (d.cashback && d.cashback.enabled && d.cashback.percent > 0) {
          if (cbWrap) cbWrap.hidden = false;
          if (cbCard) {
            cbCard.innerHTML =
              '<strong class="royal-page__cashback-title">Earn ' + d.cashback.percent + '% back as store credit</strong>' +
              '<div class="royal-page__cashback-desc">Every order automatically credits your account. Use your store credit at checkout, no code required.</div>';
          }
        } else if (cbWrap) {
          cbWrap.hidden = true;
        }

        R.renderTierGrid(
          document.getElementById('royal-page-tier-grid-wrap'),
          document.getElementById('royal-page-tier-grid'),
          d
        );

        var socialWrap = document.getElementById('royal-page-social-wrap');
        var socialList = document.getElementById('royal-page-social');
        if (d.socialPlatforms && d.socialPlatforms.length) {
          if (socialWrap) socialWrap.hidden = false;
          R.renderSocial(socialList, d.socialPlatforms, cfg, status);
        } else if (socialWrap) {
          socialWrap.hidden = true;
        }

        var earn = document.getElementById('royal-page-earn');
        if (earn) {
          earn.innerHTML = (d.earnRules && d.earnRules.length)
            ? d.earnRules.map(function (e) {
                var t = e.label || e.action;
                var d2 = e.description || '';
                return '<div class="royal-page__card">' +
                  '<div class="royal-page__card-label">' + t + '</div>' +
                  (d2 ? '<div class="royal-page__card-desc">' + d2 + '</div>' : '') +
                  '</div>';
              }).join('')
            : '<p class="royal-page__muted">Earn rules will appear here soon.</p>';
        }
        function renderRewards(d) {
          var rw = document.getElementById('royal-page-rewards');
          if (!rw) return;
          if (!(d.rewards && d.rewards.length)) {
            rw.innerHTML = '<p class="royal-page__muted">No rewards available yet. Check back soon.</p>';
            return;
          }
          var bal = d.balance || 0;
          var loggedIn = cfg.loggedIn;
          rw.innerHTML = d.rewards.map(function (x) {
            var canAfford = bal >= x.pointsCost;
            var btnLabel = !loggedIn
              ? 'Sign in to redeem'
              : canAfford
                ? 'Redeem'
                : ((x.pointsCost - bal).toLocaleString() + ' more pts');
            var btnAttrs = !loggedIn
              ? 'data-href="/account/login"'
              : ('data-reward-id="' + x.id + '"' + (canAfford ? '' : ' disabled'));
            return '<div class="royal-page__reward">' +
              '<div class="royal-page__reward-main">' +
                '<div class="royal-page__card-label">' + R.rewardLabel(x, d.currencyCode) + '</div>' +
                '<div class="royal-page__card-cost">' + x.pointsCost + ' pts</div>' +
              '</div>' +
              '<button type="button" class="royal-page__btn royal-page__redeem-btn" ' + btnAttrs + '>' +
                btnLabel +
              '</button>' +
            '</div>';
          }).join('');

          // Wire click handlers - redeem or sign-in redirect
          var btns = rw.querySelectorAll('.royal-page__redeem-btn');
          btns.forEach(function (btn) {
            btn.addEventListener('click', function () {
              if (btn.disabled) return;
              var href = btn.getAttribute('data-href');
              if (href) { window.location.href = href; return; }
              var rewardId = btn.getAttribute('data-reward-id');
              var origLabel = btn.textContent;
              btn.disabled = true;
              btn.textContent = 'Redeeming...';
              R.redeem(cfg, rewardId)
                .then(function (res) {
                  var ok = res && res.result && res.result.ok !== false;
                  if (ok) {
                    R.setStatus(status, 'success', 'Redeemed. Store credit added to your account.');
                    // Re-fetch the payload so points + store credit update
                    R.loadBalance(cfg, function (d2) {
                      renderBalances(d2);
                      renderRewards(d2);
                    });
                  } else {
                    var err = (res && res.result && res.result.error) || 'Could not redeem right now.';
                    R.setStatus(status, 'error', err);
                    btn.disabled = false;
                    btn.textContent = origLabel;
                  }
                })
                .catch(function () {
                  R.setStatus(status, 'error', 'Could not redeem. Please try again.');
                  btn.disabled = false;
                  btn.textContent = origLabel;
                });
            });
          });
        }
        var link = document.getElementById('royal-ref-link');
        if (link && d.referralLink) {
          link.textContent = d.referralLink;
          var copy = document.getElementById('royal-ref-copy');
          if (copy) copy.addEventListener('click', function () {
            try {
              navigator.clipboard.writeText(d.referralLink);
              R.setStatus(status, 'success', 'Link copied.');
            } catch (e) {
              R.setStatus(status, 'error', 'Could not copy. Select and copy manually.');
            }
          });
        }
      }, function () {
        R.setStatus(status, 'error',
          "We couldn't load your loyalty details right now. Please try again later.");
      });
    }
    init();
  })();
</script>

{% schema %}
{
  "name": "Loyalty page",
  "target": "section",
  "settings": [
    { "type": "text", "id": "hero_title", "label": "Hero title", "default": "Earn points. Get rewards." },
    { "type": "text", "id": "hero_subtitle", "label": "Hero subtitle", "default": "Join the program and earn on every order." },
    { "type": "color", "id": "theme_color", "label": "Fallback theme color", "default": "#2C2A29" },
    { "type": "text", "id": "logo_url", "label": "Logo URL" },
    { "type": "checkbox", "id": "show_earn", "label": "Show \"ways to earn\"", "default": true },
    { "type": "checkbox", "id": "show_rewards", "label": "Show rewards", "default": true },
    { "type": "checkbox", "id": "show_referral", "label": "Show referral section", "default": true },
    { "type": "text", "id": "proxy_base", "label": "App proxy base path", "default": "/apps/royal" }
  ]
}
{% endschema %}
