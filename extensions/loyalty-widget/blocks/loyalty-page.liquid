{% comment %}
  Royal Loyalty — full loyalty page block (add to a page template / section).
  Shows hero, balance, ways to earn, rewards, referral share. Section toggles
  are driven by block settings (Branding page on the paid plan). Graceful for
  signed-out visitors; accessible headings + live region.
{% endcomment %}

<link rel="stylesheet" href="{{ 'loyalty.css' | asset_url }}">

{%- assign theme = block.settings.theme_color | default: '#2C2A29' -%}

<section
  id="royal-page-root"
  style="--royal-primary: {{ theme }}; --royal-secondary: #fff;"
  data-royal-config='{
    "proxy": {{ block.settings.proxy_base | default: "/apps/royal" | json }},
    "loggedIn": {% if customer %}true{% else %}false{% endif %}
  }'
>
  <header style="background: {{ theme }}; color:#fff; padding:32px 20px; border-radius:10px;">
    {%- if block.settings.logo_url != blank -%}
      <img src="{{ block.settings.logo_url }}" alt="" style="max-height:48px;display:block;margin-bottom:12px;">
    {%- endif -%}
    <h1 style="margin:0;">{{ block.settings.hero_title | default: 'Earn points. Get rewards.' | escape }}</h1>
    <p style="margin:8px 0 0;opacity:.9;">{{ block.settings.hero_subtitle | default: 'Join the program and earn on every order.' | escape }}</p>
  </header>

  {%- if customer -%}
    <p style="margin:20px 0 4px;">Your balance: <span id="royal-page-balance" class="royal-points">…</span></p>
    {%- comment -%} Tier line hidden — backend still ships tier in payload but feature is not yet user-facing. {%- endcomment -%}
    <div id="royal-page-active-codes-wrap" hidden style="margin:16px 0;">
      <h2 style="margin:0 0 8px;">Your active codes</h2>
      <div id="royal-page-active-codes"></div>
    </div>
  {%- else -%}
    <p style="margin:20px 0;">
      <a class="royal-btn" href="/account/login" style="display:inline-block;text-decoration:none;">Sign in to view your points</a>
    </p>
  {%- endif -%}

  <div id="royal-page-cashback-wrap" hidden style="margin-top: 24px;">
    <div class="royal-card" id="royal-page-cashback"></div>
  </div>

  {%- if block.settings.show_earn -%}
    <h2>Ways to earn</h2>
    <div id="royal-page-earn"><p class="royal-muted">Loading…</p></div>
  {%- endif -%}

  {%- if block.settings.show_rewards -%}
    <h2>Rewards</h2>
    <div id="royal-page-rewards"><p class="royal-muted">Loading…</p></div>
  {%- endif -%}

  <div id="royal-page-social-wrap" hidden style="margin-top: 24px;">
    <h2>Follow us</h2>
    <div id="royal-page-social"></div>
  </div>

  {%- if block.settings.show_referral and customer -%}
    <h2>Refer a friend</h2>
    <p>Share your link — you both get rewarded.</p>
    <div class="royal-card">
      <code id="royal-ref-link" style="word-break:break-all;">Loading your link…</code>
      <button type="button" id="royal-ref-copy" class="royal-btn" style="margin-top:8px;">Copy link</button>
    </div>
  {%- endif -%}

  <p id="royal-page-status" class="royal-status" aria-live="polite"></p>
</section>

<script src="{{ 'loyalty.js' | asset_url }}" defer></script>
<script>
  (function () {
    function init() {
      var root = document.getElementById('royal-page-root');
      if (!root || !window.RoyalLoyalty) return setTimeout(init, 50);
      var R = window.RoyalLoyalty, cfg = R.readConfig(root);
      var status = document.getElementById('royal-page-status');

      /* The loyalty page renders earn rules + rewards for everyone (so
         signed-out visitors see the value prop), but only renders
         balance / tier / referral for enrolled customers. */
      R.loadBalance(cfg, function (d) {
        R.applyBranding(root, d.branding);

        if (d.branding) {
          var heroH1 = root.querySelector('header h1');
          if (heroH1 && d.branding.heroTitle) heroH1.textContent = d.branding.heroTitle;
          var heroP = root.querySelector('header p');
          if (heroP && d.branding.heroSubtitle) heroP.textContent = d.branding.heroSubtitle;
        }

        if (d.enrolled) {
          var b = document.getElementById('royal-page-balance');
          var t = document.getElementById('royal-page-tier');
          if (b) b.textContent = (d.balance || 0) + ' ' + (d.branding && d.branding.pointsName ? d.branding.pointsName.toLowerCase() : 'points');
          if (t && d.tier) t.textContent = 'Your tier: ' + d.tier;
        }

        R.renderActiveCodes(
          document.getElementById('royal-page-active-codes-wrap'),
          document.getElementById('royal-page-active-codes'),
          d.activeCodes
        );

        // Cashback callout — only when the merchant has it enabled.
        var cbWrap = document.getElementById('royal-page-cashback-wrap');
        var cbCard = document.getElementById('royal-page-cashback');
        if (d.cashback && d.cashback.enabled && d.cashback.percent > 0) {
          if (cbWrap) cbWrap.hidden = false;
          if (cbCard) {
            cbCard.innerHTML =
              '<strong>Earn ' + d.cashback.percent + '% back as store credit</strong>' +
              '<div class="royal-muted" style="font-size:13px;margin-top:4px;">' +
              'Every order automatically credits your account. Use your store credit at checkout — no code required.' +
              '</div>';
          }
        } else if (cbWrap) {
          cbWrap.hidden = true;
        }

        var socialWrap = document.getElementById('royal-page-social-wrap');
        var socialList = document.getElementById('royal-page-social');
        if (d.socialPlatforms && d.socialPlatforms.length) {
          if (socialWrap) socialWrap.hidden = false;
          R.renderSocial(socialList, d.socialPlatforms, cfg, status);
        } else if (socialWrap) {
          socialWrap.hidden = true;
        }

        var earn = document.getElementById('royal-page-earn');
        if (earn) {
          earn.innerHTML = (d.earnRules && d.earnRules.length)
            ? d.earnRules.map(function (e) {
                // Render the merchant-edited title (e.label) + description
                // (e.description) from each rule's Content section. Both
                // are pre-substituted on the server, so we just render
                // them as-is. Description is optional — omit when empty.
                var t = e.label || e.action;
                var d2 = e.description || '';
                return '<div class="royal-card">' +
                  '<div class="royal-card__label">' + t + '</div>' +
                  (d2 ? '<div class="royal-muted">' + d2 + '</div>' : '') +
                  '</div>';
              }).join('')
            : '<p class="royal-muted">Earn rules will appear here soon.</p>';
        }
        var rw = document.getElementById('royal-page-rewards');
        if (rw) {
          rw.innerHTML = (d.rewards && d.rewards.length)
            ? d.rewards.map(function (x) {
                return '<div class="royal-card"><strong>' + R.rewardLabel(x, d.currencyCode) +
                  '</strong> — ' + x.pointsCost + ' pts</div>';
              }).join('')
            : '<p class="royal-muted">No rewards available yet — check back soon.</p>';
        }
        var link = document.getElementById('royal-ref-link');
        if (link && d.referralLink) {
          link.textContent = d.referralLink;
          var copy = document.getElementById('royal-ref-copy');
          if (copy) copy.addEventListener('click', function () {
            try {
              navigator.clipboard.writeText(d.referralLink);
              R.setStatus(status, 'success', 'Link copied.');
            } catch (e) {
              R.setStatus(status, 'error', 'Could not copy — select and copy manually.');
            }
          });
        }
      }, function () {
        R.setStatus(status, 'error',
          "We couldn't load your loyalty details right now. Please try again later.");
      });
    }
    init();
  })();
</script>

{% schema %}
{
  "name": "Loyalty page",
  "target": "section",
  "settings": [
    { "type": "text", "id": "hero_title", "label": "Hero title", "default": "Earn points. Get rewards." },
    { "type": "text", "id": "hero_subtitle", "label": "Hero subtitle", "default": "Join the program and earn on every order." },
    { "type": "color", "id": "theme_color", "label": "Theme color", "default": "#2C2A29" },
    { "type": "text", "id": "logo_url", "label": "Logo URL" },
    { "type": "checkbox", "id": "show_earn", "label": "Show \"ways to earn\"", "default": true },
    { "type": "checkbox", "id": "show_rewards", "label": "Show rewards", "default": true },
    { "type": "checkbox", "id": "show_referral", "label": "Show referral section", "default": true },
    { "type": "text", "id": "proxy_base", "label": "App proxy base path", "default": "/apps/royal" }
  ]
}
{% endschema %}
