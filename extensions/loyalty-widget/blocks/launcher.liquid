{% comment %}
  Royal Loyalty — floating launcher + slide-in panel.
  App embed block (rendered site-wide via theme app embed). Layout mirrors the
  admin Branding preview: dark hero header with title + subtitle, then a hub
  list (Earn / Redeem / Refer) that drills down into each surface.
{% endcomment %}

<link rel="stylesheet" href="{{ 'loyalty.css' | asset_url }}">

{%- assign mf_position = shop.metafields.royal_loyalty.launcher_position -%}
{%- if mf_position != blank -%}
  {%- assign pos = mf_position -%}
{%- else -%}
  {%- assign pos = block.settings.position | default: 'bottom-right' -%}
{%- endif -%}
{%- comment -%}
  Primary/secondary colors are read from the shop metafields written by the
  admin Branding page (app/lib/branding-metafields.server.ts). This is what
  lets the launcher pill render with the merchant's saved color on first
  paint — before /loyalty/balance has even responded. We still fall back to
  the theme-editor block setting (and then a hardcoded default) so an
  unsaved shop or a shop on an older app version still renders something.
{%- endcomment -%}
{%- assign mf_primary = shop.metafields.royal_loyalty.primary_color -%}
{%- assign mf_secondary = shop.metafields.royal_loyalty.secondary_color -%}
{%- if mf_primary != blank -%}
  {%- assign primary = mf_primary -%}
{%- else -%}
  {%- assign primary = block.settings.primary_color | default: '#2C2A29' -%}
{%- endif -%}
{%- if mf_secondary != blank -%}
  {%- assign secondary = mf_secondary -%}
{%- else -%}
  {%- assign secondary = block.settings.secondary_color | default: '#FFFFFF' -%}
{%- endif -%}

{%- assign mf_launcher_text = shop.metafields.royal_loyalty.launcher_text -%}
{%- assign mf_panel_title = shop.metafields.royal_loyalty.panel_title -%}
{%- assign mf_panel_subtitle = shop.metafields.royal_loyalty.panel_subtitle -%}
{%- if mf_launcher_text != blank -%}
  {%- assign launcher_text = mf_launcher_text -%}
{%- else -%}
  {%- assign launcher_text = block.settings.launcher_text | default: 'Rewards' -%}
{%- endif -%}
{%- if mf_panel_title != blank -%}
  {%- assign panel_title = mf_panel_title -%}
{%- else -%}
  {%- assign panel_title = block.settings.title | default: 'Your rewards' -%}
{%- endif -%}
{%- if mf_panel_subtitle != blank -%}
  {%- assign panel_subtitle = mf_panel_subtitle -%}
{%- else -%}
  {%- assign panel_subtitle = 'Earn points on every order — redeem for rewards.' -%}
{%- endif -%}

<div
  id="royal-launcher-root"
  style="--royal-primary: {{ primary }}; --royal-secondary: {{ secondary }};"
  data-royal-config='{
    "proxy": {{ block.settings.proxy_base | default: "/apps/royal" | json }},
    "loggedIn": {% if customer %}true{% else %}false{% endif %},
    "customerId": {{ customer.id | json }}
  }'
  data-royal-ssr='{
    "metafieldPrimary":        {{ mf_primary | json }},
    "metafieldSecondary":      {{ mf_secondary | json }},
    "metafieldPosition":       {{ mf_position | json }},
    "metafieldLauncherText":   {{ mf_launcher_text | json }},
    "metafieldPanelTitle":     {{ mf_panel_title | json }},
    "metafieldPanelSubtitle":  {{ mf_panel_subtitle | json }},
    "blockPrimary":            {{ block.settings.primary_color | json }},
    "blockSecondary":          {{ block.settings.secondary_color | json }},
    "blockPosition":           {{ block.settings.position | json }},
    "renderedPrimary":         {{ primary | json }},
    "renderedSecondary":       {{ secondary | json }},
    "renderedPosition":        {{ pos | json }},
    "renderedLauncherText":    {{ launcher_text | json }},
    "renderedPanelTitle":      {{ panel_title | json }},
    "renderedPanelSubtitle":   {{ panel_subtitle | json }}
  }'
>
  <button
    type="button"
    class="royal-launcher {% if pos == 'bottom-left' %}royal-launcher--left{% else %}royal-launcher--right{% endif %}"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="royal-panel"
    id="royal-launcher-btn"
  >
    <span class="royal-launcher__icon" aria-hidden="true">&#9819;</span>
    <span class="royal-launcher__text">{{ launcher_text | escape }}</span>
  </button>

  <div
    id="royal-panel"
    class="royal-panel {% if pos == 'bottom-left' %}royal-panel--left{% endif %}"
    role="dialog"
    aria-label="{{ panel_title | escape }}"
    hidden
  >
    <div class="royal-panel__hero">
      <button type="button" id="royal-panel-back" class="royal-panel__back" aria-label="Back" hidden>&#8249;</button>
      <button type="button" id="royal-panel-close" class="royal-panel__close" aria-label="Close">&times;</button>
      <div class="royal-panel__title" id="royal-panel-title">{{ panel_title | escape }}</div>
      <div class="royal-panel__subtitle" id="royal-panel-subtitle">{{ panel_subtitle | escape }}</div>
    </div>

    <div class="royal-panel__body">
      {%- comment -%}
        State-aware status card between hero and hub. Visitor copy is SSR'd
        so logged-out shoppers see the sign-in CTA on first paint without a
        JS roundtrip. Logged-in users get a hidden placeholder that JS fills
        with their balance (member) or a join prompt (non-member) once the
        /loyalty/balance payload arrives.
      {%- endcomment -%}
      {%- if customer -%}
        <div id="royal-status-card" class="royal-status-card" hidden></div>
      {%- else -%}
        <div id="royal-status-card" class="royal-status-card royal-status-card--visitor">
          <div class="royal-status-card__title" data-loc-key="hub.visitor.title">Sign in to start earning</div>
          <div class="royal-status-card__desc" data-loc-key="hub.visitor.desc">Sign in to track your points and unlock rewards.</div>
          <a class="royal-btn" href="/account/login" data-loc-key="empty.earnSignInButton">Sign in to earn</a>
        </div>
      {%- endif -%}

      {%- comment -%} Hub: the default landing view inside the panel.
        Row labels are initially the English defaults; once the JS payload
        lands with the merchant-edited localization bundle, they get
        overwritten with the locale-appropriate copy. {%- endcomment -%}
      <div class="royal-view" data-view="hub" id="royal-view-hub">
        <button type="button" class="royal-row" data-go="earn" id="royal-row-earn">
          <span class="royal-row__label" data-loc-key="launcher.hub.earn">Earn points</span>
          <span class="royal-row__chev" aria-hidden="true">&#8250;</span>
        </button>
        <button type="button" class="royal-row" data-go="rewards" id="royal-row-rewards">
          <span class="royal-row__label" data-loc-key="launcher.hub.redeem">Redeem rewards</span>
          <span class="royal-row__chev" aria-hidden="true">&#8250;</span>
        </button>
        <button type="button" class="royal-row" data-go="referral" id="royal-row-referral">
          <span class="royal-row__label" data-loc-key="launcher.hub.refer">Refer a friend</span>
          <span class="royal-row__chev" aria-hidden="true">&#8250;</span>
        </button>
        <div class="royal-row__hint" id="royal-hub-hint" hidden></div>
      </div>

      <div class="royal-view" data-view="earn" hidden>
        <div id="royal-earn-list" class="royal-list"></div>
      </div>

      <div class="royal-view" data-view="rewards" hidden>
        <div id="royal-active-codes-wrap" hidden>
          <h3 class="royal-section-title" data-loc-key="launcher.activeCodesHeading">Your active codes</h3>
          <div id="royal-active-codes"></div>
        </div>
        <div id="royal-rewards" class="royal-list"><p class="royal-muted" data-loc-key="launcher.loadingRewards">Loading rewards…</p></div>
      </div>

      <div class="royal-view" data-view="referral" hidden>
        <div id="royal-referral-content"></div>
      </div>

      <p id="royal-status" class="royal-status" aria-live="polite"></p>
    </div>
  </div>
</div>

<script src="{{ 'loyalty.js' | asset_url }}" defer></script>
<script>
  (function () {
    try { console.log('[RoyalLoyalty] launcher block rendered'); } catch (e) {}
    var tries = 0;
    function init() {
      var root = document.getElementById('royal-launcher-root');
      if (!root || !window.RoyalLoyalty) {
        tries++;
        if (tries === 40) {
          // ~2s in: warn loudly if loyalty.js never showed up.
          try {
            console.warn(
              '[RoyalLoyalty] still waiting for window.RoyalLoyalty after 2s — ' +
              'loyalty.js probably failed to load. Check Network tab for loyalty.js.'
            );
          } catch (e) {}
        }
        return setTimeout(init, 50);
      }
      var R = window.RoyalLoyalty;
      var cfg = R.readConfig(root);
      var btn = document.getElementById('royal-launcher-btn');
      var panel = document.getElementById('royal-panel');
      var closeBtn = document.getElementById('royal-panel-close');
      var backBtn = document.getElementById('royal-panel-back');
      var status = document.getElementById('royal-status');
      var titleEl = document.getElementById('royal-panel-title');
      var subtitleEl = document.getElementById('royal-panel-subtitle');
      var payload = null;
      var loaded = false;
      var fetched = false;

      function showView(name) {
        var views = panel.querySelectorAll('.royal-view');
        views.forEach(function (v) {
          v.hidden = v.getAttribute('data-view') !== name;
        });
        backBtn.hidden = name === 'hub';
        // Status card belongs to the hub only — hide it on sub-views so the
        // sub-view content sits flush below the hero like before.
        var sc = document.getElementById('royal-status-card');
        if (sc) {
          if (name !== 'hub') {
            sc.hidden = true;
          } else if (cfg.loggedIn) {
            // Logged-in: visibility depends on whether buildStatusCard
            // filled the card. The fill function sets it visible.
            if (sc.innerHTML.trim()) sc.hidden = false;
          } else {
            // Visitor: SSR populated it; always show on hub.
            sc.hidden = false;
          }
        }
      }

      function open() {
        panel.hidden = false;
        btn.setAttribute('aria-expanded', 'true');
        closeBtn.focus();
        showView('hub');
        if (!fetched) { fetched = true; load(); }
      }

      // Fetch on page load so the launcher pill gets the merchant's branding
      // (colors + custom label) immediately — without it, the pill renders
      // the Liquid defaults until the visitor actually clicks it open.
      if (!fetched) { fetched = true; load(); }

      function close() {
        panel.hidden = true;
        btn.setAttribute('aria-expanded', 'false');
        btn.focus();
      }
      btn.addEventListener('click', function () { panel.hidden ? open() : close(); });
      closeBtn.addEventListener('click', close);
      backBtn.addEventListener('click', function () { showView('hub'); });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !panel.hidden) close();
      });

      // Hub row clicks → drill into sub-views. Rewards is the only view with
      // a logged-out gating message; earn rules + referrals render the same
      // info for everyone (anon visitors see the program but can't claim).
      panel.querySelectorAll('[data-go]').forEach(function (row) {
        row.addEventListener('click', function () {
          var name = row.getAttribute('data-go');
          showView(name);
          if (name === 'rewards') renderRewards();
          else if (name === 'earn') renderEarn();
          else if (name === 'referral') renderReferral();
        });
      });

      function applyLocaleDom() {
        // Walk every element with data-loc-key and replace its text with
        // the merchant-resolved string. Lets us localize the static Liquid
        // labels (hub rows, headings, etc.) without per-render JS plumbing.
        var nodes = panel.querySelectorAll('[data-loc-key]');
        for (var i = 0; i < nodes.length; i++) {
          var k = nodes[i].getAttribute('data-loc-key');
          var v = R.t(k, '');
          if (v) nodes[i].textContent = v;
        }
      }

      function load() {
        R.setStatus(status, 'loading', '');
        R.loadBalance(cfg, function (d) {
          payload = d;
          R.applyBranding(root, d.branding);
          applyCopy(d);
          buildHub(d);
          buildStatusCard(d);
          applyLocaleDom();
          // Pre-inject product / cart cards while we have the payload.
          try { R.injectProduct(cfg, d); } catch (e) { /* non-fatal */ }
          try { R.injectCart(cfg, d); } catch (e) { /* non-fatal */ }
          loaded = true;
        }, function (diag) {
          R.setStatus(status, 'error', R.t('error.couldNotLoad', "We couldn't load your rewards right now. Please try again later."));
          var hub = document.getElementById('royal-view-hub');
          if (diag) R.renderDiag(hub || status.parentNode, diag, 'loyalty/balance failed');
        });
      }

      function applyCopy(d) {
        var b = d.branding || {};
        // Title and subtitle both layer Branding overrides on top of the
        // localized defaults from the Localization page. Launcher pill
        // label follows the same priority.
        titleEl.textContent =
          b.programName || R.t('launcher.title', 'Your rewards');
        subtitleEl.textContent =
          b.widgetSubtitle ||
          R.t('launcher.subtitle', 'Earn points on every order — redeem for rewards.');
        var pill = document.querySelector('#royal-launcher-btn .royal-launcher__text');
        if (pill) {
          pill.textContent = b.launcherText || R.t('launcher.text', 'Rewards');
        }
      }

      function buildStatusCard(d) {
        var card = document.getElementById('royal-status-card');
        if (!card) return;
        // Visitor card was rendered by Liquid (SSR) — leave it alone.
        if (!cfg.loggedIn) { card.hidden = false; return; }
        // Logged-in (member OR not-yet-enrolled): always show the balance
        // dashboard. Non-members render as 0 balance — they get enrolled
        // automatically on first earn event, at which point this same card
        // just starts showing the real number.
        var b = d.branding || {};
        var pointsName = b.pointsName || 'points';
        var bal = d.balance || 0;
        var tier = d.currentTier && d.currentTier.name ? d.currentTier.name : '';

        var html =
          '<div class="royal-status-card__balanceWrap">' +
            '<div class="royal-status-card__balance">' + bal + '</div>' +
            '<div class="royal-status-card__pointsname">' + escapeHtml(pointsName) + '</div>' +
            (tier ? '<div class="royal-status-card__tier">' + escapeHtml(tier) + '</div>' : '') +
          '</div>';

        // Live store-credit balance — only shown when the customer actually
        // has any. Distinct from the cashback callout below, which is about
        // FUTURE earnings.
        var sc = d.storeCreditBalance || 0;
        if (sc > 0) {
          var scLabel = R.t('hub.member.storeCreditBalance', 'Store credit balance');
          var scAmount = R.formatMoney
            ? R.formatMoney(sc, d.storeCreditCurrency || d.currencyCode)
            : (d.storeCreditCurrency || d.currencyCode || '') + ' ' + sc.toFixed(2);
          html +=
            '<div class="royal-status-card__credit">' +
              '<span class="royal-status-card__creditLabel">' + escapeHtml(scLabel) + '</span>' +
              '<span class="royal-status-card__creditAmount">' + escapeHtml(scAmount) + '</span>' +
            '</div>';
        }

        // Cashback callout — appears between balance and Next Reward whenever
        // the merchant has cashback turned on. Tells the member what they'll
        // get *back* on every order on top of points.
        if (d.cashback && d.cashback.enabled && (d.cashback.percent || 0) > 0) {
          var cbTemplate = R.t(
            'hub.member.cashbackLine',
            'Earn {percent}% back as store credit on every order.'
          );
          var cbLine = String(cbTemplate).replace(
            /\{percent\}/g,
            String(d.cashback.percent)
          );
          html +=
            '<div class="royal-status-card__cashback">' +
              escapeHtml(cbLine) +
            '</div>';
        }

        // "Next reward" section — shows the cheapest reward to give the
        // dashboard purpose beyond a static number. If the cheapest is
        // affordable, swap the progress bar for a Ready badge. Skipped
        // entirely when no rewards are configured.
        var rewards = (d.rewards || []).slice().sort(function (a, b) {
          return (a.pointsCost || 0) - (b.pointsCost || 0);
        });
        if (rewards.length) {
          var next = rewards[0];
          for (var i = 0; i < rewards.length; i++) {
            if ((rewards[i].pointsCost || 0) > bal) { next = rewards[i]; break; }
          }
          var canAfford = bal >= (next.pointsCost || 0);
          var pct = canAfford
            ? 100
            : Math.max(2, Math.min(100, Math.floor((bal / (next.pointsCost || 1)) * 100)));
          var label = R.rewardLabel(next, d.currencyCode);
          html +=
            '<div class="royal-status-card__divider"></div>' +
            '<div class="royal-status-card__nextLabel">' +
              R.t('hub.member.nextReward', 'Next reward') +
            '</div>' +
            '<div class="royal-status-card__nextName">' + escapeHtml(label) + '</div>' +
            '<div class="royal-status-card__bar"><div class="royal-status-card__barFill" style="width:' + pct + '%"></div></div>' +
            '<div class="royal-status-card__nextMeta">' +
              (canAfford
                ? '<span class="royal-status-card__ready">' +
                    R.t('hub.member.readyToRedeem', 'Ready to redeem') +
                  '</span>'
                : bal + ' / ' + next.pointsCost) +
            '</div>';
        }

        card.innerHTML = html;
        card.hidden = false;
      }

      function buildHub(d) {
        // Row visibility mirrors the admin live-preview exactly: driven
        // only by the merchant's section toggles, not by content. Empty
        // states are handled inside each sub-view, so the hub always
        // looks identical to what the admin shows.
        var b = d.branding || {};
        var hasEarn = b.showEarn !== false;
        var hasRewards = b.showRewards !== false;
        var hasReferral = b.showReferral !== false;
        document.getElementById('royal-row-earn').hidden = !hasEarn;
        document.getElementById('royal-row-rewards').hidden = !hasRewards;
        document.getElementById('royal-row-referral').hidden = !hasReferral;
        var hint = document.getElementById('royal-hub-hint');
        if (!hasEarn && !hasRewards && !hasReferral) {
          hint.hidden = false;
          hint.textContent = R.t('empty.programBeingSetUp', 'Your loyalty program is being set up. Check back soon.');
        }
      }

      function renderEarn() {
        var list = document.getElementById('royal-earn-list');
        if (!payload) return;
        var rules = (payload.earnRules || []);
        // Logged-out customers see ways to earn but with a sign-in CTA at
        // the top so they understand they need an account to start banking
        // points. Empty list = merchant hasn't configured any earn rules.
        var html = '';
        if (!cfg.loggedIn) {
          html +=
            '<p class="royal-muted">' +
            R.t('empty.earnSignedOut', 'Sign in or create an account to start earning points on every order.') +
            '</p>' +
            '<a class="royal-btn" href="/account/login" style="text-decoration:none;display:inline-block;margin-bottom:12px;">' +
            R.t('empty.earnSignInButton', 'Sign in to earn') +
            '</a>';
        }
        if (!rules.length) {
          html += '<p class="royal-muted">' +
            R.t('empty.earnRules', 'No ways to earn yet — check back soon.') +
            '</p>';
          list.innerHTML = html;
          return;
        }
        list.innerHTML = html;
        rules.forEach(function (r) {
          var row = document.createElement('div');
          row.className = 'royal-card';
          // Server pre-substitutes the merchant's title + description with
          // shop-currency-aware values, so the storefront just renders the
          // text as-is. Empty description = no sub-line (keeps the card
          // visually tight when the merchant clears it).
          var label = r.label || r.action;
          var desc = r.description || '';
          row.innerHTML =
            '<div class="royal-card__label">' + escapeHtml(label) + '</div>' +
            (desc ? '<div class="royal-muted">' + escapeHtml(desc) + '</div>' : '');
          list.appendChild(row);
        });
      }

      function renderRewards() {
        var wrap = document.getElementById('royal-rewards');
        if (!payload) return;
        var d = payload;

        // Active codes block
        R.renderActiveCodes(
          document.getElementById('royal-active-codes-wrap'),
          document.getElementById('royal-active-codes'),
          d.activeCodes,
          status
        );

        var preface = '';
        if (!cfg.loggedIn) {
          var signInLink =
            '<a href="/account/login">' +
            R.t('empty.rewardsSignInLink', 'Sign in') +
            '</a>';
          preface =
            '<p class="royal-muted">' +
            R.tSubstitute(
              R.t(
                'empty.rewardsSignedOut',
                'These are the rewards you can redeem with your points. {signInLink} or create an account to start earning.',
              ),
              { signInLink: signInLink },
            ) +
            '</p>';
        }
        if (!d.rewards || !d.rewards.length) {
          wrap.innerHTML = preface + '<p class="royal-muted">' +
            R.t('empty.rewards', 'No rewards available yet — check back soon.') +
            '</p>';
          return;
        }
        wrap.innerHTML = preface;
        d.rewards.forEach(function (rw) {
          var card = document.createElement('div');
          card.className = 'royal-card';
          var canAfford = d.enrolled && (d.balance || 0) >= rw.pointsCost;
          var label = R.rewardLabel(rw, d.currencyCode);
          card.innerHTML =
            '<div class="royal-card__label">' + escapeHtml(label) + '</div>' +
            '<div class="royal-muted">' + rw.pointsCost + ' points</div>';
          var rb = document.createElement('button');
          rb.className = 'royal-btn';
          rb.type = 'button';
          rb.textContent = cfg.loggedIn
            ? R.t('reward.redeemButton', 'Redeem')
            : R.t('reward.signInToRedeemButton', 'Sign in to redeem');
          rb.disabled = !canAfford;
          if (!cfg.loggedIn) {
            rb.addEventListener('click', function () {
              window.location.href = '/account/login';
            });
            rb.disabled = false;
            rb.classList.add('royal-btn--ghost');
          } else if (!canAfford) {
            rb.title = d.enrolled
              ? R.t('tooltip.notEnoughPoints', 'Not enough points yet')
              : R.t('tooltip.signUpToRedeem', 'Sign up to redeem');
          } else {
            rb.addEventListener('click', function () {
              rb.disabled = true;
              R.setStatus(status, 'loading', R.t('status.redeeming', 'Redeeming…'));
              R.redeem(cfg, rw.id).then(function (res) {
                // Server returns { ok: true, result: { ok, error?, discountCode? } }.
                // Surface inner.error so a failed redemption isn't silently
                // dressed up as success.
                var inner = (res && res.result) || res || {};
                if (inner.ok === false) {
                  rb.disabled = false;
                  R.setStatus(
                    status,
                    'error',
                    inner.error ||
                      R.t('error.couldNotRedeem', "We couldn't redeem that reward. Please try again."),
                  );
                  return;
                }
                if (inner.discountCode) {
                  R.setStatus(
                    status,
                    'success',
                    R.tSubstitute(
                      R.t('status.rewardRedeemedWithCode', 'Reward redeemed — your code is {code}.'),
                      { code: inner.discountCode },
                    ),
                  );
                } else {
                  R.setStatus(status, 'success', R.t('status.rewardRedeemed', 'Reward redeemed.'));
                }
              }).catch(function () {
                rb.disabled = false;
                R.setStatus(status, 'error',
                  R.t('error.couldNotRedeem', "We couldn't redeem that reward. Please try again."));
              });
            });
          }
          card.appendChild(rb);
          wrap.appendChild(card);
        });
      }

      function renderReferral() {
        var box = document.getElementById('royal-referral-content');
        if (!payload) return;
        if (!cfg.loggedIn) {
          box.innerHTML =
            '<p class="royal-muted" style="margin-bottom:12px;">' +
            R.t('refer.descSignedOut', 'Share your personal link with friends. When they place their first order, you both earn rewards.') +
            '</p>' +
            '<a class="royal-btn" href="/account/login" style="text-decoration:none;display:inline-block;">' +
            R.t('refer.signInCta', 'Sign in to get your link') +
            '</a>';
          return;
        }
        if (!payload.referralLink) {
          box.innerHTML = '<p class="royal-muted">' +
            R.t('refer.unavailable', "Referrals aren't available right now.") +
            '</p>';
          return;
        }
        box.innerHTML =
          '<p class="royal-muted" style="margin-bottom:8px;">' +
          R.t('refer.descSignedIn', 'Share your link. You both earn when friends place their first order.') +
          '</p>' +
          '<div class="royal-active-code__row">' +
          '<code class="royal-active-code__code" id="royal-ref-link"></code>' +
          '<button type="button" class="royal-btn royal-btn--ghost" id="royal-ref-copy">' +
          R.t('refer.copyButton', 'Copy') +
          '</button>' +
          '</div>';
        document.getElementById('royal-ref-link').textContent = payload.referralLink;
        document.getElementById('royal-ref-copy').addEventListener('click', function () {
          R.copyText(payload.referralLink).then(function () {
            var b = document.getElementById('royal-ref-copy');
            b.textContent = R.t('refer.copiedButton', 'Copied!');
            setTimeout(function () { b.textContent = R.t('refer.copyButton', 'Copy'); }, 1500);
          });
        });
      }

      function escapeHtml(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }
    }
    init();
  })();
</script>

